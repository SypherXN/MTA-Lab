MTA_DATABASE_PATH=./data/mta_lab.db
MTA_WRITE_API_KEY=dev-key-change-me
# Optional: require X-API-Key on GET /api/dashboard/* and GET /api/automation/context|runs/*
MTA_READ_API_KEY=
MTA_CORS_ORIGINS=http://localhost:8080,https://your-user.github.io
MTA_INITIAL_SIMULATED_CASH=10000
MTA_BACKUP_DIR=./data/backups
MTA_BACKUP_KEEP=14
MTA_RATE_LIMIT_PER_MINUTE=120
MTA_RATE_LIMIT_ENABLED=true
MTA_ALERT_WEBHOOK_URL=
MTA_ALERT_COOLDOWN_MINUTES=60
MTA_WATCHER_PCT_THRESHOLD=1.5
MTA_PLAN_HISTORY_KEEP=20
# Dashboard login (separate from automation X-API-Key)
MTA_DASHBOARD_PASSWORD=
MTA_SESSION_SECRET=change-me-session-secret
MTA_SESSION_TTL_HOURS=168
# Run one lane at a time (recommended on OCI E2.1.Micro shared with other services)
MTA_SEQUENTIAL_LANES=true
MTA_LANE_LOCK_TTL_MINUTES=45
# Optional override for agent plan JSON directory (default: repo plans/)
# MTA_PLANS_REPO_DIR=../plans

# Uptime monitoring (scripts/uptime-check.sh + install-cron --with-uptime)
# MTA_UPTIME_LOCAL_URL=http://127.0.0.1:8000/health
# MTA_UPTIME_PUBLIC_URL=https://your-api.example.com/health
# MTA_UPTIME_ALERT_COOLDOWN_MINUTES=30
# MTA_ALERT_WEBHOOK_URL=   # Slack incoming webhook — required for uptime alerts
